{
  "name": "@blizzard-api/root",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Putro",
  "description": "A series of helpers to interact with the Blizzard Battle.net API",
  "repository": "https://github.com/Pewtro/blizzard-api",
  "type": "module",
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >=26"
  },
  "packageManager": "pnpm@11.1.3",
  "keywords": [
    "blizzard",
    "battlenet",
    "battle.net",
    "bnet",
    "api",
    "world of warcraft",
    "warcraft",
    "wow",
    "classic",
    "retail",
    "starcraft",
    "sc2",
    "diablo",
    "d3",
    "hs",
    "hearthstone"
  ],
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.3",
    "@changesets/cli": "2.31.0",
    "@putstack/eslint-config-typescript": "4.18.1",
    "@putstack/prettier-config": "2.0.0",
    "@size-limit/preset-small-lib": "12.1.0",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/ui": "4.1.7",
    "eslint": "10.4.1",
    "eslint-plugin-jsdoc": "62.9.0",
    "lefthook": "2.1.9",
    "npm-run-all2": "9.0.1",
    "prettier": "3.8.3",
    "publint": "0.3.21",
    "size-limit": "12.1.0",
    "size-limit-node-esbuild": "0.4.0",
    "ts-to-zod": "5.1.0",
    "tsdown": "0.22.1",
    "tsx": "4.22.3",
    "turbo": "2.9.16",
    "typedoc": "0.28.19",
    "typedoc-github-theme": "0.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7",
    "zod": "4.4.3"
  },
  "scripts": {
    "build:docs": "typedoc",
    "build": "turbo build",
    "generate:zod": "tsx ./scripts/generate-zod.ts",
    "generate": "npm-run-all -l generate:zod \"prettier:write ./generated\" \"lint:fix ./generated\"",
    "lint:ci": "npm-run-all -p -l typecheck stylecheck \"lint .\"",
    "lint:fix": "pnpm lint --fix",
    "lint": "eslint --format stylish --max-warnings 0 --cache",
    "prepare": "lefthook install",
    "prettier:write": "prettier --write",
    "release": "changeset publish",
    "size": "size-limit",
    "stylecheck": "prettier --check .",
    "test:coverage": "pnpm run test --coverage",
    "test:ui": "vitest --ui --coverage",
    "test:watch": "vitest watch",
    "test": "vitest run --testTimeout 15000",
    "typecheck": "tsc"
  }
}
